# ─────────────────────────────────────────────────────────────────────────────
# Door — your garage door
# Copy to `.env` and edit. docker compose will pick this up automatically.
# ─────────────────────────────────────────────────────────────────────────────

# Garage admin API. nginx proxies /api/* to this URL.
# Use the docker service name if Garage runs in the same compose stack,
# or a LAN host/IP (e.g. http://192.168.1.10:3903) for an external Garage.
GARAGE_UPSTREAM_URL=http://garage:3903

# Garage S3 API. nginx proxies /s3/* to this URL.
GARAGE_S3_UPSTREAM_URL=http://garage:3900

# Optional: pre-seed the admin token so the Settings page is pre-filled.
# Leave blank to enter it manually in the UI.
GARAGE_ADMIN_TOKEN=

# Optional: override the API URL the browser uses. Default `/api` goes through
# the nginx proxy. Only change this if you're bypassing the proxy.
GARAGE_API_URL=/api

# Enable the nginx /s3/* reverse proxy.
#   false (default) — browser talks to Garage's S3 port directly. Required for
#                     normal (SigV4-signed) S3 access. Configure CORS per bucket.
#   true            — nginx proxies /s3/* to GARAGE_S3_UPSTREAM_URL. Only works
#                     for anonymous/unsigned S3; SigV4 signatures break through
#                     a path-rewriting proxy.
GARAGE_S3_PROXY=false
